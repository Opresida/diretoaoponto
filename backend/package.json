{
  "name": "diretoaoponto-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend da plataforma de pesquisa eleitoral Direito ao Ponto (Neon + Drizzle + Express + WS + Base).",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "seed": "tsx seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@neondatabase/serverless": "^0.9.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.31.2",
    "ethers": "^6.13.1",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "json-canonicalize": "^1.0.6",
    "jsonwebtoken": "^9.0.2",
    "merkletreejs": "^0.4.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.22.7",
    "solc": "^0.8.26",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
