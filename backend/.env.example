# ─── Banco (Neon PostgreSQL serverless) ──────────────────────────────
DATABASE_URL=postgres://USER:PASS@HOST.neon.tech/diretoaoponto?sslmode=require

# ─── Auth (JWT) ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Storage (Cloudflare R2 / S3) ────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=pesquisa-midia
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Filas (Redis / Upstash) ─────────────────────────────────────────
REDIS_URL=

# ─── Integridade blockchain (Base) ───────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
ANCHOR_PRIVATE_KEY=
ANCHOR_CONTRACT_ADDRESS=
HASH_SALT=

# ─── Servidor ────────────────────────────────────────────────────────
PORT=3000
# URL pública do portal de verificação (usada nos recibos: PORTAL_URL/v/:code)
PORTAL_URL=https://verificar.diretoaoponto.com.br
# Origem do app Portal p/ links de cadastro (/cadastro/:token)
PUBLIC_PORTAL_ORIGIN=http://localhost:5174
# CORS allowlist (CSV de origens permitidas em prod). Vazio em dev = libera localhost:5173-5177.
# Ex.: https://app.diretoaoponto.com.br,https://verificar.diretoaoponto.com.br
CORS_ORIGINS=
